# Memesh deployment env. Copy to `.env` and fill in every value marked REQUIRED.
# The `.env` file is gitignored. Never commit secrets.
#
# Generate any 32+ character secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# This file is consumed by `docker compose` at the repo root. Compose substitutes
# these values into docker-compose.yml at boot.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
# Optional: change the host port the api binds to. Defaults to 3001.
# API_HOST_PORT=3001

# ---------------------------------------------------------------------------
# Postgres (REQUIRED)
# Set POSTGRES_PASSWORD to a long random string. The Compose stack will fail
# to start if it is missing.
# ---------------------------------------------------------------------------
POSTGRES_USER=memesh
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=memesh

# ---------------------------------------------------------------------------
# Redis (REQUIRED)
# Set to a long random string. Even though Redis is only reachable on the
# internal Docker network, we still require auth as defense-in-depth.
# ---------------------------------------------------------------------------
REDIS_PASSWORD=replace-with-a-long-random-password

# ---------------------------------------------------------------------------
# API secrets (REQUIRED, must be 32+ characters each, must differ from each other)
# Generate each with the node one-liner at the top of this file.
# ---------------------------------------------------------------------------
SERVER_SECRET_KEY=replace-with-a-32-character-random-string
JWT_SECRET=replace-with-a-different-32-character-random-string

# Optional — defaults are fine for Phase 1.
JWT_ISSUER=memesh
JWT_AUDIENCE=memesh-api
JWT_CUSTOMER_AUDIENCE=memesh-customer
QR_KEY_ID=1

# ---------------------------------------------------------------------------
# WordPress one-way sync (OPTIONAL)
# When all three are set, new customers are mirrored to WP as `subscriber`
# users. When any are unset, the sync seam is disabled.
# ---------------------------------------------------------------------------
# WP_BASE_URL=https://memesh.co.il/wp-json/wp/v2
# WP_SYNC_USER=memesh-sync
# WP_SYNC_APP_PASSWORD=replace-with-the-application-password-from-wp-admin

# ---------------------------------------------------------------------------
# First-admin seed (REQUIRED when running `docker compose run --rm api pnpm seed:admin`)
# The seed script reads these once, hashes the password with scrypt, and stores
# only the hash. Running the seed twice with the same phone is a no-op.
# ---------------------------------------------------------------------------
SEED_ADMIN_PHONE=050-000-0000
SEED_ADMIN_PASSWORD=pick-a-strong-12-plus-char-password
SEED_ADMIN_FIRST_NAME=Yanay
SEED_ADMIN_LAST_NAME=Mizrahi
# SEED_ADMIN_EMAIL=owner@memesh.co.il
