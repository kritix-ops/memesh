# Memesh env. Copy to `.env` (root, gitignored) and fill in every value
# marked REQUIRED. The runtime entries listed here are what the seed script,
# WP-sync, SMS provider, and local dev API read.
#
# Generate any 32+ character secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# DATABASE_URL is NOT in this file. It lives in packages/db/.env.local and
# is auto-synced from the Vercel ↔ Neon integration (vercel env pull). The
# seed-admin script loads both files via Node's --env-file-if-exists flag.
#
# In production, the Vercel project (memesh-opal.vercel.app) carries the
# same set of variables as Environment Variables — set them in the
# Vercel dashboard, not here.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# API secrets (REQUIRED, each must be 32+ characters and must differ)
# ---------------------------------------------------------------------------
SERVER_SECRET_KEY=replace-with-a-32-character-random-string
JWT_SECRET=replace-with-a-different-32-character-random-string

# ---------------------------------------------------------------------------
# Identity claims (defaults are fine; only override if you know why)
# ---------------------------------------------------------------------------
JWT_ISSUER=memesh
JWT_AUDIENCE=memesh-api
JWT_CUSTOMER_AUDIENCE=memesh-customer
QR_KEY_ID=1

# ---------------------------------------------------------------------------
# WordPress one-way sync (OPTIONAL)
# When all three are set, new customers are mirrored to WP as `subscriber`
# users. Unset to disable the sync seam entirely.
# ---------------------------------------------------------------------------
# WP_BASE_URL=https://memesh.co.il/wp-json/wp/v2
# WP_SYNC_USER=memesh-sync
# WP_SYNC_APP_PASSWORD=replace-with-the-application-password-from-wp-admin

# ---------------------------------------------------------------------------
# SMS provider
# 'console' (default) logs every outbound SMS to stdout — safe and free for
# local dev.
# 'pulseem' sends via Pulseem (pulseem.co.il), the production account Yanai
# signed up for; requires PULSEEM_API_KEY and PULSEEM_FROM_NUMBER. Real spend.
# '019' is a DRAFT alternative provider that was never wired to a live
# account — kept in code but not recommended.
# ---------------------------------------------------------------------------
SMS_PROVIDER=console
# PULSEEM_API_KEY=replace-with-the-api-key-from-pulseem-dashboard
# PULSEEM_FROM_NUMBER=MEMESH
# PULSEEM_BASE_URL=https://api.pulseem.com
# SMS_019_TOKEN=
# SMS_019_SOURCE=MEMESH
# SMS_019_ENDPOINT=https://019sms.co.il/api/test

# ---------------------------------------------------------------------------
# First-admin seed (REQUIRED when running `pnpm --filter=@memesh/api seed:admin`)
# The seed script reads these, scrypt-hashes the password, and stores only
# the hash. Re-running with the same phone is a no-op by default; to rotate
# the password for an existing admin, set SEED_ADMIN_FORCE_RESET=1 below.
# ---------------------------------------------------------------------------
SEED_ADMIN_PHONE=050-000-0000
SEED_ADMIN_PASSWORD=pick-a-strong-12-plus-char-password
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
# SEED_ADMIN_EMAIL=owner@memesh.co.il
# SEED_ADMIN_FORCE_RESET=1   # uncomment + re-run to overwrite an existing password
