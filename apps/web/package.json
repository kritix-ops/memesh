{
  "name": "@memesh/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:api-bundle": "node scripts/build-api-bundle.mjs",
    "build": "node scripts/build-api-bundle.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "node scripts/build-api-bundle.mjs && tsc --noEmit",
    "test": "node --test --import tsx src/lib/api/customers.test.ts src/lib/api/punch.test.ts src/lib/api/cards.test.ts src/lib/api/admin.test.ts src/lib/api/staff.test.ts"
  },
  "dependencies": {
    "@memesh/api": "workspace:*",
    "@memesh/brand": "workspace:*",
    "@memesh/customer-auth": "workspace:*",
    "@memesh/staff-auth": "workspace:*",
    "@memesh/web-shared": "workspace:*",
    "@yudiel/react-qr-scanner": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.7"
  }
}
