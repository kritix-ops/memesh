# Memesh web app env. Copy to `apps/web/.env.local` (gitignored) if you want to
# override anything. The defaults work for local dev with the API on port 3001.

# Base URL for API calls. Default `/api` works in two topologies:
#   1. Dev: Vite proxies /api/* to the Fastify server (see vite.config.ts).
#   2. Prod single-origin Cloudways: the reverse proxy handles /api/*.
# For a split topology (Vercel + Cloudways API on a separate subdomain), set:
#   VITE_API_URL=https://api.memesh.co.il
# VITE_API_URL=/api

# Override the proxy target if your API is not on localhost:3001 in dev.
# Read by vite.config.ts at server startup.
# API_DEV_TARGET=http://localhost:3001
