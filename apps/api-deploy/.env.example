# apps/api-deploy environment — the canonical API deploy for api.memesh.co.il.
# Pull live values with `vercel env pull .env.local` after the Vercel project
# is linked (Phase 6). Anything marked "MUST match" is shared with the
# frontends' Vercel projects — drift here causes silent customer logouts and
# unverifiable staff JWTs.

# Runtime
NODE_ENV=production
LOG_LEVEL=info

# Database (Neon, single shared instance across all deploys)
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require

# Auth secrets — MUST match the values used by any other API copy still
# running (apps/web during Phase 2-5). Rotating either invalidates all
# active staff JWTs and all 7-day customer cookies on the next refresh.
SERVER_SECRET_KEY=at-least-32-characters-of-random-secret
JWT_SECRET=at-least-32-characters-of-random-secret
JWT_ISSUER=memesh
JWT_AUDIENCE=memesh-api
JWT_CUSTOMER_AUDIENCE=memesh-customer

# QR token signing key id (string label; the raw key material is derived
# from SERVER_SECRET_KEY via @memesh/qr-engine).
QR_KEY_ID=1

# Split-subdomain topology — populated in Phase 6 when api.memesh.co.il
# goes live. Leave unset during Phase 2 to keep apps/web (same-origin)
# unaffected if this deploy is brought up early for smoke-tests.
CORS_ALLOWED_ORIGINS=https://staff.memesh.co.il,https://admin.memesh.co.il,https://my.memesh.co.il
COOKIE_DOMAIN=.memesh.co.il

# SMS provider (live = pulseem; console logs to stdout for dev/staging).
SMS_PROVIDER=pulseem
PULSEEM_API_KEY=
PULSEEM_FROM_NUMBER=
PULSEEM_BASE_URL=

# Email-OTP fallback provider (live = resend; console logs to stdout).
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=

# WordPress one-way sync (optional; leave unset if WP is offline).
WP_BASE_URL=
WP_SYNC_USER=
WP_SYNC_APP_PASSWORD=

# WooCommerce webhook + reconciliation cron.
WC_WEBHOOK_SECRET=
CRON_SECRET=
WC_API_URL=
WC_API_CONSUMER_KEY=
WC_API_CONSUMER_SECRET=
WC_RECONCILE_LOOKBACK_HOURS=48
