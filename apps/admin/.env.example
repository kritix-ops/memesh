# apps/admin environment — the admin surface at admin.memesh.co.il.
# Copy to apps/admin/.env.local (gitignored) to override during dev.

# Base URL for API calls. Production points at the canonical API deploy
# (apps/api-deploy → api.memesh.co.il). For local dev, override to your
# Fastify server on port 3001 — cookies set there are accepted on
# cross-origin fetches from this Vite dev server (apps/api allows
# origin:true in dev).
VITE_API_URL=https://api.memesh.co.il
# VITE_API_URL=http://localhost:3001

# Optional public link surfaced on the "no permission" screen so a
# staff-role user accidentally on admin.memesh.co.il can hop back to
# the POS without typing the URL. Defaults to the prod staff origin.
VITE_STAFF_URL=https://staff.memesh.co.il
# VITE_STAFF_URL=http://localhost:3010
