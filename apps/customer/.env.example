# apps/customer environment — the personal area at my.memesh.co.il.
# Copy to apps/customer/.env.local (gitignored) to override during dev.

# Base URL for API calls. Production points at the canonical API deploy
# (apps/api-deploy → api.memesh.co.il). In dev, override to the Fastify
# server on localhost:3001 — apps/api's dev CORS reflects any origin so
# the cross-origin OTP login cookie is accepted on subsequent calls.
VITE_API_URL=https://api.memesh.co.il
# VITE_API_URL=http://localhost:3001
