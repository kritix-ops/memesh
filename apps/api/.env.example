NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
LOG_LEVEL=info

# 32+ char random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET_KEY=replace-with-a-32-character-random-string

# Active key id for new QR tokens. Bump when rotating; keep old keys in the
# resolver for backward-compat until all old tickets have expired.
QR_KEY_ID=1

# 32+ char random string for signing JWTs. MUST be different from
# SERVER_SECRET_KEY (different rotation cadence, different risk surface).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-32-character-random-string-different-from-server-key
JWT_ISSUER=memesh
JWT_AUDIENCE=memesh-api
JWT_CUSTOMER_AUDIENCE=memesh-customer

# Optional — one-way WordPress sync (Memesh customer → WP user). Leave unset
# during dev and the sync seam is disabled.
# WP_BASE_URL=https://memesh.co.il/wp-json/wp/v2
# WP_SYNC_USER=memesh-sync
# WP_SYNC_APP_PASSWORD=replace-with-the-application-password-from-wp-admin

# SMS provider. 'console' (default) logs each message to stdout — safe for dev.
# Set to '019' to send real SMS via 019 SMS (Israeli telco). When 019 is set,
# SMS_019_TOKEN and SMS_019_SOURCE are required. Endpoint defaults to the test
# sandbox (https://019sms.co.il/api/test); flip to https://019sms.co.il/api
# for production sends (real money).
SMS_PROVIDER=console
# SMS_019_TOKEN=replace-with-019-api-token-from-019-admin
# SMS_019_SOURCE=MEMESH
# SMS_019_ENDPOINT=https://019sms.co.il/api/test
