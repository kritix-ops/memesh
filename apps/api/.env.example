NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
LOG_LEVEL=info

# 32+ char random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET_KEY=replace-with-a-32-character-random-string

# Active key id for new QR tokens. Bump when rotating; keep old keys in the
# resolver for backward-compat until all old tickets have expired.
QR_KEY_ID=1
