# apps/staff environment — the POS surface at staff.memesh.co.il.
# Copy to apps/staff/.env.local (gitignored) to override during dev.

# Base URL for API calls. In production this points at the canonical API
# deploy (apps/api-deploy → api.memesh.co.il). In dev, override to your
# local Fastify server (apps/api on port 3001) so cookies set there are
# accepted on cross-origin fetches back from this Vite dev server.
VITE_API_URL=https://api.memesh.co.il
# VITE_API_URL=http://localhost:3001
