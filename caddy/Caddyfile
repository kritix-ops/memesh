# Memesh production reverse proxy.
#
# Single origin (single-origin Cloudways topology, see
# _plans/2026-06-18-api-deployment-kit.md §2.1):
#   - https://{$DOMAIN}/api/*  →  api:3001 (prefix stripped)
#   - https://{$DOMAIN}/*      →  /srv/web (the built apps/web/dist)
#
# TLS is auto-provisioned via Let's Encrypt. The {$LETSENCRYPT_EMAIL}
# placeholder is required so renewal failures are reported somewhere a human
# will see.
#
# DOMAIN and LETSENCRYPT_EMAIL come from the .env file via docker-compose.

{
  email {$LETSENCRYPT_EMAIL}
  # Default ACME issuer is Let's Encrypt; keep it implicit.
  # Caddy auto-renews; nothing to configure.
}

{$DOMAIN} {
  encode zstd gzip

  header {
    # 1 year HSTS — apply only after the first successful HTTPS response,
    # so a misconfigured first deploy can be fixed without lock-out.
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options    "nosniff"
    Referrer-Policy           "no-referrer"
    # CSP is intentionally NOT set here — the SPA inlines styles via
    # styled-objects and a strict CSP would need careful tuning. A future
    # chunk can add a tested policy.
    -Server
  }

  # API: strip the /api prefix before forwarding so app routes stay /auth/login
  # etc. (the API doesn't know about the /api prefix).
  handle /api/* {
    uri strip_prefix /api
    reverse_proxy api:3001 {
      # Pass the client's real IP so the api's rate limiter (per-IP) works.
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}
      # The api logs each request via pino; surface 5xx upstream as Caddy too.
      health_uri /health
      health_interval 30s
      health_timeout 5s
    }
  }

  # SPA: serve the built dist. try_files falls back to /index.html so the
  # surface-switcher tabs (which use React state, not URL routing) survive
  # a hard refresh.
  handle {
    root * /srv/web
    encode zstd gzip
    try_files {path} /index.html
    file_server
  }

  log {
    output stdout
    format json
    level INFO
  }
}
